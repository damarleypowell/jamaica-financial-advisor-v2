# ══════════════════════════════════════════════════════════════════════════════
# Gotham Financial — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=generate_a_random_hex_string_here

# ── AI Services ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/jamaica_financial_advisor?schema=public

# ── Email (Nodemailer) ──────────────────────────────────────────────────────
# Leave EMAIL_USER and EMAIL_PASS blank to use console transport (dev mode)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# EMAIL_FROM="Gotham Financial <noreply@gothamfinancial.com>"
# APP_URL=http://localhost:3000

# ── Alpaca Markets (US stock trading) ────────────────────────────────────────
# Get keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true

# ── Python Analytics Service ─────────────────────────────────────────────────
PYTHON_ANALYTICS_URL=http://localhost:8000

# ── CORS (comma-separated origins for production) ────────────────────────────
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
