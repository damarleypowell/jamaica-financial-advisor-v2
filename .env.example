# ══════════════════════════════════════════════════════════════════════════════
# Gotham Financial — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=generate_a_random_hex_string_here

# ── AI Services ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/jamaica_financial_advisor?schema=public

# ── Email (Nodemailer) ──────────────────────────────────────────────────────
# Leave EMAIL_USER and EMAIL_PASS blank to use console transport (dev mode)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# EMAIL_FROM="Gotham Financial <noreply@gothamfinancial.com>"
# APP_URL=http://localhost:3000

# ── Alpaca Markets (US stock trading) ────────────────────────────────────────
# Get keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true

# ── Python Analytics Service ─────────────────────────────────────────────────
PYTHON_ANALYTICS_URL=http://localhost:8000

# ── Admin ──────────────────────────────────────────────────────────────────────
# Comma-separated list of emails that have admin access
ADMIN_EMAILS=admin@gothamfinancial.com

# ── Redis (Production rate limiting) ──────────────────────────────────────────
# Optional: set REDIS_URL for persistent rate limiting. Falls back to in-memory.
# REDIS_URL=redis://default:password@host:6379

# ── Stripe (Payments & Subscriptions) ─────────────────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Create products/prices in Stripe Dashboard, then paste price IDs:
STRIPE_PRICE_BASIC=price_basic_monthly_id
STRIPE_PRICE_PRO=price_pro_monthly_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly_id
APP_URL=http://localhost:3000

# ── CORS (comma-separated origins for production) ────────────────────────────
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
