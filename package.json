{
  "name": "gotham-financial",
  "version": "2.0.0",
  "description": "Gotham Financial — AI-powered Investment & Trading Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "dev:all": "concurrently -n API,UI -c green,cyan \"node --watch src/server.js\" \"node --watch frontend-server.js\"",
    "legacy": "node server.legacy.js",
    "frontend": "node frontend-server.js",
    "frontend:dev": "node --watch frontend-server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "node scripts/migrate-json-to-pg.js"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.1.3",
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.0.0",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "financial": "^0.2.4",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.0",
    "otplib": "^12.0.1",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.39.1",
    "qrcode": "^1.5.4",
    "stripe": "^20.4.1",
    "technicalindicators": "^3.1.0",
    "winston": "^3.11.0",
    "yahoo-finance2": "^2.11.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^6.0.0"
  }
}
