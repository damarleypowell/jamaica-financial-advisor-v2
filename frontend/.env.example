# ── Google Sign-In ──────────────────────────────────────────────────
# Get this from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application), add http://localhost:3001 as allowed origin
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Apple Sign-In ────────────────────────────────────────────────────
# Get this from: https://developer.apple.com → Certificates, IDs & Profiles → Identifiers → Services IDs
# Requires Apple Developer Program membership
# VITE_APPLE_CLIENT_ID=com.yourcompany.gotham-financial
