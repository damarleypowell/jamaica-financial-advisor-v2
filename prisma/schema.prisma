// ─── Prisma Schema for Gotham Financial ─────────────────────────────────────
// Run `npx prisma migrate dev` to apply migrations
// Run `npx prisma generate` to regenerate the client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP
  STOP_LIMIT
}

enum OrderStatus {
  PENDING
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  EXPIRED
  REJECTED
}

enum TransactionType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
  FEE
  DIVIDEND
  INTEREST
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum AlertCondition {
  ABOVE
  BELOW
  PERCENT_CHANGE_ABOVE
  PERCENT_CHANGE_BELOW
}

enum PaymentType {
  DEPOSIT
  WITHDRAWAL
  SUBSCRIPTION
  REFUND
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String
  passwordHash    String
  salt            String
  kycStatus       KycStatus @default(NONE)
  riskProfile     String?
  settings        Json      @default("{}")
  twoFactorSecret String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  wallets            Wallet[]
  portfolioPositions PortfolioPosition[]
  orders             Order[]
  transactions       Transaction[]
  watchlists         Watchlist[]
  financialGoals     FinancialGoal[]
  chatHistory        ChatHistory[]
  notifications      Notification[]
  priceAlerts        PriceAlert[]
  auditLogs          AuditLog[]
  payments           Payment[]
  subscription       Subscription?
  portfolioSnapshots PortfolioSnapshot[]

  @@index([email])
  @@map("users")
}

model Wallet {
  id          String   @id @default(uuid())
  userId      String
  currency    String   @db.VarChar(3)
  balance     Decimal  @default(0) @db.Decimal(18, 4)
  heldBalance Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@index([userId])
  @@map("wallets")
}

model PortfolioPosition {
  id       String   @id @default(uuid())
  userId   String
  symbol   String
  market   String   @default("JSE")
  shares   Decimal  @db.Decimal(18, 6)
  avgCost  Decimal  @db.Decimal(18, 4)
  currency String   @default("JMD") @db.VarChar(3)
  isPaper  Boolean  @default(false)
  openedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, symbol])
  @@map("portfolio_positions")
}

model Order {
  id           String      @id @default(uuid())
  userId       String
  symbol       String
  market       String      @default("JSE")
  side         OrderSide
  orderType    OrderType
  status       OrderStatus @default(PENDING)
  quantity     Decimal     @db.Decimal(18, 6)
  filledQty    Decimal     @default(0) @db.Decimal(18, 6)
  limitPrice   Decimal?    @db.Decimal(18, 4)
  stopPrice    Decimal?    @db.Decimal(18, 4)
  avgFillPrice Decimal?    @db.Decimal(18, 4)
  isPaper      Boolean     @default(false)
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([userId, status])
  @@index([symbol])
  @@map("orders")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  orderId     String?
  type        TransactionType
  symbol      String?
  market      String?
  shares      Decimal?        @db.Decimal(18, 6)
  price       Decimal?        @db.Decimal(18, 4)
  totalAmount Decimal         @db.Decimal(18, 4)
  feeAmount   Decimal         @default(0) @db.Decimal(18, 4)
  currency    String          @default("JMD") @db.VarChar(3)
  isPaper     Boolean         @default(false)
  createdAt   DateTime        @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, createdAt])
  @@index([orderId])
  @@map("transactions")
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  name      String
  symbols   String[]
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("watchlists")
}

model FinancialGoal {
  id            String     @id @default(uuid())
  userId        String
  name          String
  targetAmount  Decimal    @db.Decimal(18, 4)
  currentAmount Decimal    @default(0) @db.Decimal(18, 4)
  targetDate    DateTime?
  category      String?
  status        GoalStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("financial_goals")
}

model ChatHistory {
  id        String   @id @default(uuid())
  userId    String
  role      String
  content   String
  context   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("chat_history")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String?
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model PriceAlert {
  id          String         @id @default(uuid())
  userId      String
  symbol      String
  condition   AlertCondition
  targetValue Decimal        @db.Decimal(18, 4)
  isTriggered Boolean        @default(false)
  createdAt   DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([symbol, isTriggered])
  @@map("price_alerts")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model Payment {
  id         String        @id @default(uuid())
  userId     String
  provider   String
  externalId String?
  type       PaymentType
  amount     Decimal       @db.Decimal(18, 4)
  currency   String        @default("JMD") @db.VarChar(3)
  status     PaymentStatus @default(PENDING)
  metadata   Json?
  createdAt  DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([externalId])
  @@map("payments")
}

model Subscription {
  id                     String             @id @default(uuid())
  userId                 String             @unique
  plan                   SubscriptionPlan   @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd       DateTime?
  stripeSubscriptionId   String?
  createdAt              DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

model PortfolioSnapshot {
  id         String   @id @default(uuid())
  userId     String
  totalValue Decimal  @db.Decimal(18, 4)
  date       DateTime
  breakdown  Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@map("portfolio_snapshots")
}
